<div class="contact section-content">
	<header class="section-header contact-header">
		<p class="section-eyebrow">Contact</p>
		<h2 class="section-title">Let&rsquo;s build something better.</h2>
		<p class="section-lead">
			Whether you need technical direction, hands-on delivery, or a fresh
			perspective on a difficult platform, we&rsquo;d be glad to hear from you.
		</p>
	</header>

	<article class="contact-card">
		<div class="contact-intro">
			<p class="contact-label">Start a conversation</p>
			<h3>Tell us what you&rsquo;re working on.</h3>
			<p>
				A short note is plenty. We&rsquo;ll get back to you to understand the
				challenge and see where NeAnSy can help.
			</p>
		</div>

		<div class="contact-methods">
			<a class="contact-method" data-contact-email>
				<span class="method-label">Email</span>
				<span class="method-value" data-contact-value>Reveal email address</span>
				<span class="method-arrow" aria-hidden="true">&nearr;</span>
			</a>

			<a class="contact-method" data-contact-phone>
				<span class="method-label">Phone</span>
				<span class="method-value" data-contact-value>Reveal phone number</span>
				<span class="method-arrow" aria-hidden="true">&nearr;</span>
			</a>
		</div>

		<p class="contact-note">
			Based in London, working with teams across the UK and beyond.
		</p>
	</article>

	<noscript>
		<p class="contact-noscript">
			Please enable JavaScript to reveal our contact details.
		</p>
	</noscript>
</div>

<script>
	const decode = (values: number[]) =>
		String.fromCharCode(...values.map((value) => value - 7));

	const contact = document.querySelector('.contact');
	const emailLink = contact?.querySelector<HTMLAnchorElement>(
		'[data-contact-email]',
	);
	const phoneLink = contact?.querySelector<HTMLAnchorElement>(
		'[data-contact-phone]',
	);

	const email = decode([
		111, 108, 115, 115, 118, 71, 117, 108, 104, 117, 122, 128, 53, 106, 118,
		116,
	]);
	const phoneDisplay = decode([
		50, 59, 59, 39, 62, 63, 39, 60, 55, 56, 55, 39, 61, 61, 61, 59,
	]);
	const phoneHref = decode([
		50, 59, 59, 62, 63, 60, 55, 56, 55, 61, 61, 61, 59,
	]);

	if (emailLink) {
		emailLink.href = `mailto:${email}`;
		emailLink.ariaLabel = `Email ${email}`;
		const value = emailLink.querySelector('[data-contact-value]');
		if (value) value.textContent = email;
	}

	if (phoneLink) {
		phoneLink.href = `tel:${phoneHref}`;
		phoneLink.ariaLabel = `Call ${phoneDisplay}`;
		const value = phoneLink.querySelector('[data-contact-value]');
		if (value) value.textContent = phoneDisplay;
	}
</script>

