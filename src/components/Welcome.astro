<script>
	import { tsParticles } from '@tsparticles/engine';
	import { loadSlim } from '@tsparticles/slim';
	import GlitchedWriter from 'glitched-writer';

	const initParticles = async () => {
		await loadSlim(tsParticles);
        await tsParticles.load({
            id: "particles",
            url: "./tsparticles.json"
        });	
	};

	const initGlitchedWriter = async () => {
		const GWParams = 'encrypted';

		await Promise.all([
			new GlitchedWriter('#ural', GWParams).write('ural'),
			new GlitchedWriter('#cillary', GWParams).write('cillary'),
			new GlitchedWriter('#stems', GWParams).write('stems'),
		]);
	};

	try {
		await Promise.all([
			initParticles(),
			initGlitchedWriter(),
		]);
	} catch (error) {
		console.warn('Client initialisation failed', error);
	}
</script>

